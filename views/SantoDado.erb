|____/ \__,_|_| |_|\__\___/|____/ \__,_|\__,_|\___/                                                   
</pre>
</header>

<main>
    <div class="main">
        <div class="terminal-logs">
            <div class="log-entry">
              <span class="timestamp">[04:04]</span> Iniciando protocolo Rol.exe...
            </div>
            <div class="log-entry">
              <span class="timestamp">[05:00]</span> Localización actual: Santiago de Compostela.
            </div>
            <div class="log-entry blink" style="color: yellow">
              <span class="timestamp_Advertencia">[WARNING]</span> Dado Rodando. Pifia Inminente.
            </div>
                <div class="nav-links">
                    <a id="pixel" href="/" class="cmd-btn">[ /SANTOPIXEL.MP3 ]</a> 
                    <a id="soundcloud" href="#" class="cmd-btn">[ /REDDIT.ISO ]</a>
                    <a id="youtube" href="#" class="cmd-btn">[ /YOUTUBE.AVI ]</a>    
                    <a id="tiktok" href="#" class="cmd-btn">[ /ITCH.IO ]</a>
                    <a id="twitter" href="#" class="cmd-btn">[ /DRIVETHRU.RPG ]</a>
                    <a id="instagram" href="#" class="cmd-btn">[ /INSTAGRAM.MOV ]</a>
                </div>
            </div>
        </div>
        <div class="videos-container">
            <iframe 
              class="video-flexible"
              src="https://www.youtube.com/embed/u4ecB57jFhI?si=oeA8qzuXjqcZoNQe" 
              title="Reproductor de vídeo de YouTube" 
              frameborder="0" 
              allowfullscreen>
            </iframe>
        </div>
        <div class="partners">
            <h3> > SYSTEM RESOURCES (POWERED BY):</h3>
            <div class="sponsor-grid"></div>
            <p style="font-size: 0.75rem; color: #999999; margin-top: 10px">
            root@santopixel:~$ sudo apt-get install any-sponsor<br />
            <span class="blink" style="font-size: 0.8rem">Waiting for handshake...</span>
            </p>
        </div>
    </div>
    <footer>
      &copy; <%= Time.now.year %> Santo Pixel && SantoDado | Santiago de Compostela
    </footer>
</main>
